# Discord OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://bots.kartersanamo.com/api/auth/callback

# Discord Bot (server-side guild/member API calls)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=680569558754656280
# Required for ticket "Open in Discord" links in the browser
NEXT_PUBLIC_DISCORD_GUILD_ID=680569558754656280

# Owner override — always receives full access
OWNER_DISCORD_ID=

# Session secret (generate a random 32+ char string)
SESSION_SECRET=

# MySQL (read-only user recommended)
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# App URL (used for redirects)
NEXT_PUBLIC_APP_URL=https://bots.kartersanamo.com

# Bot Control API (Phase 2 — localhost only)
CONTROL_API_SECRET=
CONTROL_API_URL=http://127.0.0.1:8787
CONTROL_API_HOST=127.0.0.1
CONTROL_API_PORT=8787
MINECADIA_BOTS_ROOT=/root/Discord Bots/Minecadia

# MinecadiaTickets local API (dashboard /close) — same secret as CONTROL_API is fine
TICKETS_BOT_API_URL=http://127.0.0.1:8788
TICKETS_BOT_API_PORT=8788
TICKETS_BOT_API_SECRET=

# Optional: systemd unit names per bot (e.g. minecadia-games.service)
# BOT_GAMES_SYSTEMD_UNIT=
# BOT_TICKETS_SYSTEMD_UNIT=

# Per-bot Discord tokens for DM inbox (fallback: DISCORD_BOT_TOKEN)
# BOT_GAMES_TOKEN=
# BOT_TICKETS_TOKEN=
# BOT_MANAGEMENT_TOKEN=
# BOT_UTILITIES_TOKEN=
# BOT_STAFF_TOKEN=
# BOT_LEADER_TOKEN=

# MySQL write user (optional — falls back to DB_USER)
DB_WRITE_USER=
DB_WRITE_PASSWORD=
